# Docker Dash — Caddy HTTPS Reverse Proxy (Example)
# Usage: docker compose --profile tls up -d
#
# Replace YOUR_HOST with your actual IP or domain:
#   - LAN:    https://192.168.1.100
#   - Domain: https://dash.example.com
#
# For domains, remove the `tls internal` block to get Let's Encrypt auto-certs.

https://YOUR_HOST {
    reverse_proxy docker-dash:{$APP_PORT:8101}

    tls internal {
        on_demand
    }

    header {
        Strict-Transport-Security "max-age=31536000"
        X-Content-Type-Options "nosniff"
        X-Frame-Options "DENY"
    }

    encode gzip zstd
}
