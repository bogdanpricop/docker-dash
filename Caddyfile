# Docker Dash — Caddy HTTPS Reverse Proxy
# Usage: docker compose --profile tls up -d
# Access: https://192.168.13.20:8443 (self-signed cert)

https://192.168.13.20 {
    reverse_proxy docker-dash:8101

    tls internal {
        on_demand
    }

    header {
        Strict-Transport-Security "max-age=31536000"
        X-Content-Type-Options "nosniff"
        X-Frame-Options "DENY"
    }

    encode gzip zstd
}
